{
  "global": {
    "files": "/src/{01,02}/**/*.*"
  },
  "dependencies": [
    {
      "url": "https://github.com/abap2xlsx/abap2xlsx",
      "folder": "/deps",
      "files": "/src/**/*.*"
    }
  ],
  "syntax": {
    "version": "v757",
    "errorNamespace": "^(Z|Y)"
  },
  "rules": {
    "check_syntax": true,
    "parser_error": true,
    "unknown_types": true,
    "xml_consistency": true
  }
}
