{
  "global": {
    "files": "/../../src/{01,02}/**/*.*"
  },
  "syntax": {
    "version": "v757",
    "errorNamespace": "^(Z|Y)"
  },
  "rules": {
    "double_space": true,
    "indentation": true,
    "whitespace_end": true,
    "empty_statement": true,
    "sequential_blank": { "severity": "Warning" }
  }
}
